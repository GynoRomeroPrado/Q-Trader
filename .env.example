# ============================================
# Trading Bot Configuration
# Copy this file to .env and fill in your values
# ============================================

# --- Exchange (Binance) ---
EXCHANGE_ID=binance
EXCHANGE_API_KEY=your_binance_api_key_here
EXCHANGE_SECRET=your_binance_secret_here
EXCHANGE_SANDBOX=true

# --- Trading ---
TRADING_SYMBOL=BTC/USDT
TRADING_TIMEFRAME=5m
TRADING_INTERVAL_SECONDS=10
MAX_POSITION_PCT=0.02
STOP_LOSS_PCT=0.03
MAX_OPEN_TRADES=3
TRADE_COOLDOWN_SECONDS=60

# --- Dashboard & API ---
DASHBOARD_PORT=8888
JWT_SECRET=change_this_to_a_random_64_char_string
API_KEY=your_dashboard_login_key

# --- Database ---
DUCKDB_PATH=data/analytics.duckdb
SQLITE_PATH=data/trades.db

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=data/bot.log
