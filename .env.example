# ═══════════════════════════════════════════════════════════
# Q-Trader — Environment Configuration
# ═══════════════════════════════════════════════════════════
#
# IMPORTANT: Copy this file to .env and fill in your real values.
#   cp .env.example .env
#   chmod 600 .env
#
# In production (Ubuntu), this file must be owned by the
# 'tradingbot' user with permissions 600.
#
# ═══════════════════════════════════════════════════════════

# ── Exchange Credentials ──────────────────────────────────
EXCHANGE_ID=binance
EXCHANGE_API_KEY=YOUR_API_KEY_HERE
EXCHANGE_SECRET=YOUR_SECRET_HERE
EXCHANGE_SANDBOX=true

# Market type: spot | future | swap (perpetual)
# IMPORTANT: Futures have ~4x lower fees (0.02% vs 0.10% maker)
MARKET_TYPE=spot

# ── Trading Configuration ─────────────────────────────────
TRADING_SYMBOL=BTC/USDT
TRADING_TIMEFRAME=5m
TRADING_INTERVAL_SECONDS=10
PAPER_TRADING_MODE=true
PAPER_TRADING_INITIAL_BALANCE=1000.0
MAX_POSITION_PCT=0.02
STOP_LOSS_PCT=0.03
MAX_OPEN_TRADES=3
TRADE_COOLDOWN_SECONDS=60

# ── Futures-Specific (only used if MARKET_TYPE=future|swap) ─
FUTURES_LEVERAGE=1
FUTURES_MARGIN_MODE=isolated

# ── Risk Controls ─────────────────────────────────────────
# Daily drawdown limit (bot stops trading for the day)
MAX_DAILY_LOSS_PCT=0.02
MAX_DRAWDOWN_PCT=0.05

# Consecutive loss protection
MAX_CONSECUTIVE_LOSSES=3
LOSS_STREAK_COOLDOWN_SEC=900

# Trailing stop-loss (% below peak)
TRAILING_STOP_PCT=0.015

# Paper trading simulation realism
PAPER_FEE_PCT=0.00075
PAPER_SLIPPAGE_BPS=2.0

# ── Sentiment Oracle (LLM) ───────────────────────────────
LLM_SENTIMENT_PROVIDER=gemini
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE
CLAUDE_API_KEY=
SENTIMENT_POLLING_SECONDS=300
SENTIMENT_PANIC_THRESHOLD=-0.5

# ── Performance Toggles ──────────────────────────────────
# High-performance event loop (winloop on Windows, uvloop on Linux)
USE_FAST_LOOP=true
# Numba JIT compilation for OBI calculation (~50x faster)
USE_NUMBA=true
# Use LangGraph state machine (adds ~10-50ms overhead per tick)
USE_LANGGRAPH=false
# Use orjson for fast JSON serialization
USE_ORJSON=true

# ── Dashboard & API ──────────────────────────────────────
DASHBOARD_PORT=8888
# SECURITY: Change these to strong random values before production!
JWT_SECRET=CHANGE_ME_TO_RANDOM_STRING
API_KEY=CHANGE_ME_TO_SECURE_KEY
# Allow /api/demo endpoint to issue JWT without credentials (dev only)
ALLOW_DEMO_MODE=false

# ── Telegram Alerts (Optional) ───────────────────────────
# Get a bot token from @BotFather on Telegram
# Get your chat_id by messaging @userinfobot
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Database Paths ───────────────────────────────────────
# Relative to project root (or absolute paths)
DUCKDB_PATH=data/analytics.duckdb
SQLITE_PATH=data/trades.db

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=data/bot.log
